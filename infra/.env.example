# =============================================================================
# streamforge — environment variable reference
#
# Copy this file to .env and fill in your values before starting any service.
# Lines beginning with # are comments. Never commit a .env file.
# =============================================================================

# -----------------------------------------------------------------------------
# Shared — required by all services
# -----------------------------------------------------------------------------

# Redis connection string used by BullMQ (ingest + transcode)
SF_REDIS_URL=redis://localhost:6379

# S3-compatible storage configuration (all services)
SF_S3_BUCKET=streamforge
SF_S3_REGION=us-east-1
SF_S3_ACCESS_KEY_ID=your-access-key-id
SF_S3_SECRET_ACCESS_KEY=your-secret-access-key

# Custom S3 endpoint — set this when using a local S3-compatible service
# such as MinIO. Leave unset when using real AWS S3.
# SF_S3_ENDPOINT=http://localhost:9000

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

# One of: development | production | test
NODE_ENV=development

# One of: debug | info | warn | error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# ingest service
# -----------------------------------------------------------------------------

# HTTP port the ingest API listens on
INGEST_PORT=3000

# Maximum accepted upload size in bytes
# Default: 2147483648 (2 GB)
INGEST_MAX_UPLOAD_SIZE=2147483648

# -----------------------------------------------------------------------------
# transcode service
# -----------------------------------------------------------------------------

# Maximum number of video jobs processed in parallel
# Set to 1 on machines with limited CPU. Default: 2
TRANSCODE_CONCURRENCY=2

# Directory for temporary working files during transcoding
# Must be writable by the transcode process. Default: /tmp/streamforge
TRANSCODE_TMP_DIR=/tmp/streamforge

# Duration of each HLS segment in seconds. Default: 6
TRANSCODE_SEGMENT_DURATION=6

# -----------------------------------------------------------------------------
# serve service
# -----------------------------------------------------------------------------

# HTTP port the streaming service listens on
SERVE_PORT=3002

# Cache-Control max-age for .ts segments (seconds)
# Segments are content-addressed and immutable — a long TTL is safe.
# Default: 86400 (1 day)
SERVE_CACHE_TTL=86400

# Allowed CORS origins. Use * to allow all origins (development only).
# In production, set to a comma-separated list of allowed origins.
# Default: *
SERVE_CORS_ORIGINS=*