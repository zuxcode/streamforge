# syntax=docker/dockerfile:1

# ---------------------------------------------------------------------------
# Stage 1: install dependencies
# ---------------------------------------------------------------------------
FROM oven/bun:1-alpine AS deps

WORKDIR /app

COPY package.json bun.lock* bunfig.toml  ./

COPY apps/serve/package.json ./apps/serve/
COPY apps/ingest/package.json ./apps/ingest/
COPY apps/transcode/package.json ./apps/transcode/

COPY packages/env/package.json ./packages/env/
COPY packages/logger/package.json ./packages/logger/
COPY packages/payload/package.json ./packages/payload/
COPY packages/queue/package.json ./packages/queue/
COPY packages/storage/package.json ./packages/storage/
COPY packages/types/package.json ./packages/types/
COPY packages/utils/package.json ./packages/utils/

RUN bun install --frozen-lockfile --prod

# ---------------------------------------------------------------------------
# Stage 2: build
# ---------------------------------------------------------------------------
FROM oven/bun:1-alpine AS build

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/~ ./~

# COPY --from=deps /app/apps/serve/node_modules ./apps/serve/node_modules
# COPY --from=deps /app/apps/ingest/node_modules ./apps/ingest/node_modules

COPY --from=deps /app/apps/transcode/node_modules ./apps/transcode/node_modules
COPY --from=deps /app/packages ./packages

COPY . .

RUN bun build apps/transcode/src/index.ts \
      --outdir apps/transcode/dist \
      --target bun \
      --minify

# ---------------------------------------------------------------------------
# Stage 3: runtime (includes ffmpeg)
# ---------------------------------------------------------------------------
FROM oven/bun:1-alpine AS runtime

# Pin ffmpeg version if reproducibility matters for your transcode pipeline
RUN apk add --no-cache ffmpeg

WORKDIR /app

ENV NODE_ENV=production

RUN addgroup -S streamforge && adduser -S -G streamforge streamforge

# Writable temp directory for transcoding working files.
# The app creates this via a relative "./tmp" mkdir call, which resolves to
# /app/tmp given WORKDIR /app — must exist and be owned by the runtime user
# before the app starts, since /app itself is root-owned by default.
RUN mkdir -p /app/tmp && chown streamforge:streamforge /app/tmp

COPY --from=build --chown=streamforge:streamforge /app/apps/transcode/dist ./dist

USER streamforge


CMD ["bun", "run", "dist/index.js"]